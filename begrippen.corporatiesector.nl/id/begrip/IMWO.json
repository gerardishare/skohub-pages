{
  "id": "https://begrippen.corporatiesector.nl/id/begrip/IMWO",
  "type": "Concept",
  "prefLabel": {
    "nl": "Informatiemodel Woongebouwen"
  },
  "altLabel": {
    "nl": [
      "IMWO"
    ]
  },
  "definition": {
    "nl": "Een informatiemodel in ontwikkeling (via digiGO) dat de informatiestructuur van woongebouwen beschrijft en een begrippenkader omvat voor gebouwgerelateerde begrippen."
  },
  "scopeNote": {
    "nl": [
      "IMWO wordt ontwikkeld in het kader van het Digitaal Stelsel Gebouwde Omgeving (DSGO) en is gerelateerd aan het Begrippenkader Corporatiesector via gedeelde vastgoedbegrippen."
    ]
  },
  "related": [
    {
      "id": "https://begrippen.corporatiesector.nl/id/begrip/Vastgoed",
      "prefLabel": {
        "nl": "Vastgoed"
      }
