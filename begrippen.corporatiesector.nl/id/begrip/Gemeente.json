{
  "id": "https://begrippen.corporatiesector.nl/id/begrip/Gemeente",
  "type": "Concept",
  "prefLabel": {
    "nl": "Gemeente"
  },
  "definition": {
    "nl": "De lokale overheid die prestatieafspraken maakt met woningcorporaties en huurdersorganisaties over de volkshuisvestelijke inzet van de corporatie in het werkgebied."
  },
  "scopeNote": {
    "nl": [
      "Gemeenten stellen een woonvisie op op basis waarvan corporaties een bod uitbrengen. Op basis van woonvisie en bod worden lokale prestatieafspraken gesloten. Gemeenten hebben ook een rol bij huisvesting van bijzondere doelgroepen."
    ]
  },
  "related": [
    {
      "id": "https://begrippen.corporatiesector.nl/id/begrip/Belanghoudende",
      "prefLabel": {
        "nl": "Belanghoudende partij"
      }
    },
    {
      "id": "https://begrippen.corporatiesector.nl/id/begrip/LokalePrestatieafspraken",
      "prefLabel": {
        "nl": "Lokale prestatieafspraken"
      }
    },
    {
      "id": "https://begrippen.corporatiesector.nl/id/begrip/Werkgebied",
      "prefLabel": {
        "nl": "Werkgebied"
      }
    }
