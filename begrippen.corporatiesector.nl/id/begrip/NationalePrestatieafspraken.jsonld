{
  "id": "https://begrippen.corporatiesector.nl/id/begrip/NationalePrestatieafspraken",
  "type": "Concept",
  "prefLabel": {
    "nl": "Nationale Prestatieafspraken"
  },
  "altLabel": {
    "nl": [
      "NPA"
    ]
  },
  "definition": {
    "nl": "De landelijke afspraken die zijn gemaakt tussen het Ministerie van VRO, Aedes en de Woonbond over de bijdrage van woningcorporaties aan de volkshuisvestelijke opgave voor de periode 2022–2030."
  },
  "scopeNote": {
    "nl": [
      "De Nationale Prestatieafspraken bevatten doelstellingen op het gebied van nieuwbouw, betaalbaarheid, verduurzaming en leefbaarheid. Zij vormen de context voor lokale prestatieafspraken."
    ]
  },
  "related": [
    {
      "id": "https://begrippen.corporatiesector.nl/id/begrip/MinisterieVRO",
      "prefLabel": {
        "nl": "Ministerie van Volkshuisvesting en Ruimtelijke Ordening"
      }
    },
    {
      "id": "https://begrippen.corporatiesector.nl/id/begrip/VolkshuisvestelijkePrioriteiten",
      "prefLabel": {
        "nl": "Volkshuisvestelijke prioriteiten"
      }
    },
    {
      "id": "https://begrippen.corporatiesector.nl/id/begrip/LokalePrestatieafspraken",
      "prefLabel": {
        "nl": "Lokale prestatieafspraken"
      }
    },
    {
      "id": "https://begrippen.corporatiesector.nl/id/begrip/Verduurzaming",
      "prefLabel": {
        "nl": "Verduurzaming"
      }
    }
  ],
  "inScheme": [
    {
      "id": "https://begrippen.corporatiesector.nl/id/BegrippenkaderCorporatiesector",
      "title": {
        "nl": "Begrippenkader Corporatiesector"
      }
    }
  ],
  "inSchemeAll": [
    {
      "id": "https://begrippen.corporatiesector.nl/id/BegrippenkaderCorporatiesector"
    }
  ],
